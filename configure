#!/usr/bin/env sh
set -eu

prefix="/usr/local"
bindir=""
sysconfdir="/etc/logcut"
varlibdir="/var/lib/logcut"
logdir="/var/log"
lockdir="/var/lock"
go_bin="go"
version=""
src="./cmd/logcut"

show_help() {
  cat <<'EOF'
Usage: ./configure [OPTIONS]

Configure logcut before running make and make install.

Options:
  --prefix=PATH        install prefix, default: /usr/local
  --bindir=PATH        binary install directory, default: PREFIX/bin
  --sysconfdir=PATH    config directory, default: /etc/logcut
  --varlibdir=PATH     state directory, default: /var/lib/logcut
  --logdir=PATH        log directory, default: /var/log
  --lockdir=PATH       lock directory, default: /var/lock
  --go=PATH            Go command, default: go
  --version=VERSION    build/package version override
  --src=PATH           Go package source, default: ./cmd/logcut
  --help               show this help

Examples:
  ./configure
  ./configure --prefix=/usr
  ./configure --prefix=/usr --bindir=/usr/sbin
  make
  sudo make install
EOF
}

for arg in "$@"; do
  case "$arg" in
    --prefix=*) prefix=${arg#*=} ;;
    --bindir=*) bindir=${arg#*=} ;;
    --sysconfdir=*) sysconfdir=${arg#*=} ;;
    --varlibdir=*) varlibdir=${arg#*=} ;;
    --logdir=*) logdir=${arg#*=} ;;
    --lockdir=*) lockdir=${arg#*=} ;;
    --go=*) go_bin=${arg#*=} ;;
    --version=*) version=${arg#*=} ;;
    --src=*) src=${arg#*=} ;;
    --help|-h) show_help; exit 0 ;;
    *) echo "Unknown option: $arg" >&2; show_help; exit 2 ;;
  esac
done

if [ -z "$bindir" ]; then
  bindir="$prefix/bin"
fi

if [ -z "$version" ] && [ -f VERSION.txt ]; then
  version=$(tr -d '[:space:]' < VERSION.txt)
fi

cat > config.mk <<EOF
# Generated by ./configure. Do not edit manually unless you know what you are doing.
PREFIX := $prefix
BINDIR := $bindir
SYSCONFDIR := $sysconfdir
VARLIBDIR := $varlibdir
LOGDIR := $logdir
LOCKDIR := $lockdir
GO := $go_bin
SRC := $src
EOF

if [ -n "$version" ]; then
  printf 'VERSION := %s\n' "$version" >> config.mk
fi

cat <<EOF
Configuration complete.

  PREFIX      = $prefix
  BINDIR      = $bindir
  SYSCONFDIR  = $sysconfdir
  VARLIBDIR   = $varlibdir
  LOGDIR      = $logdir
  LOCKDIR     = $lockdir
  GO          = $go_bin
  SRC         = $src
  VERSION     = ${version:-from devtool default}

Next steps:
  make
  sudo make install
EOF
